#!/usr/bin/env bash
set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/../../.." && pwd)"
cd "$ROOT"

if [ ! -x "$ROOT/.venv/bin/python" ]; then
  echo "Missing virtual environment. Run ./skills/open-perplexity/bin/setup first." >&2
  exit 1
fi

exec "$ROOT/.venv/bin/python" -m open_perplexity.cli "$@"
